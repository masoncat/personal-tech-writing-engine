{
  "name": "personal-tech-writing-engine",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "tests/*"
  ],
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest",
    "verify": "vitest --run && npm run test --workspace @ptce/e2e",
    "dev:server": "npm run dev --workspace @ptce/mock-server",
    "dev:cli": "npm run dev --workspace @ptce/cli"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
